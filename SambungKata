AddBtn.Size = UDim2.new(0.8,0,0,30)
AddBtn.Text = "Tambah Kata"
AddBtn.BackgroundColor3 = Color3.fromRGB(0,200,255)

Instance.new("UICorner", AddBtn)

-- DATABASE
local kataDB = {
    a = {"ayam","anjing","apel"},
    b = {"bola","buku","batu"}
}

-- FUNCTION UPDATE
local function updateOutput(huruf)
    huruf = string.lower(huruf or "")
    HurufDisplay.Text = "Huruf: "..huruf

    if kataDB[huruf] then
        Output.Text = table.concat(kataDB[huruf], ", ")
    else
        Output.Text = "Tidak ada kata"
    end
end

-- TAMBAH KATA
AddBtn.MouseButton1Click:Connect(function()
    local h = string.lower(HurufBox.Text)
    local k = string.lower(KataBox.Text)

    if h ~= "" and k ~= "" then
        kataDB[h] = kataDB[h] or {}

        for _,v in pairs(kataDB[h]) do
            if v == k then return end
        end

        table.insert(kataDB[h], k)
        KataBox.Text = ""

        updateOutput(h)
    end
end)

-- MANUAL INPUT
ManualHuruf.FocusLost:Connect(function()
    updateOutput(ManualHuruf.Text)
end)

-- AUTO DETECT (AMAN, ga bakal error)
task.spawn(function()
    while true do
        local found = false

        -- scan semua TextLabel di game
        for _,v in pairs(game:GetDescendants()) do
            if v:IsA("TextLabel") and #v.Text == 1 then
                updateOutput(v.Text)
                found = true
                break
            end
        end

        if not found then
            HurufDisplay.Text = "Huruf: (manual / belum ketemu)"
        end

        task.wait(1)
    end
end)
