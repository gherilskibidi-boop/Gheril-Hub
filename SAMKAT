-- Normalisasi: semua lowercase, buang duplikat
do
    local seen = {}
    local clean = {}
    for _, w in ipairs(dictionary) do
        local lw = string.lower(w)
        if not seen[lw] then
            seen[lw] = true
            table.insert(clean, lw)
        end
    end
    dictionary = clean
end

