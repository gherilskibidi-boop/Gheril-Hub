-- ============================================================
--  HELPER FUNCTIONS
-- ============================================================

-- Ambil huruf terakhir dari sebuah kata
local function getLastLetter(word)
    if type(word) ~= "string" or #word == 0 then return "" end
    return string.sub(word, -1)
end

-- Ambil semua kata yang diawali prefix, diurutkan A-Z
local function getWordsByPrefix(prefix)
    local results = {}
    prefix = string.lower(prefix)
    for _, word in ipairs(dictionary) do
        if string.sub(word, 1, #prefix) == prefix then
            table.insert(results, word)
        end
    end
    table.sort(results)
    return results
end

-- Tambah kata baru ke kamus (cek duplikat)
local function addWord(word)
    word = string.lower(string.gsub(word, "%s+", ""))
    if word == "" then return false, "Kata tidak boleh kosong." end
    for _, w in ipairs(dictionary) do
        if w == word then return false, "Kata sudah ada di kamus." end
    end
    table.insert(dictionary, word)
    return true, "Kata berhasil ditambahkan!"
end

