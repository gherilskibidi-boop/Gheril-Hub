-- ============================================================
--  UPDATE UI
-- ============================================================
local function updateUI()
    local prefix = getLastLetter(lastWord)

    -- Update labels
    awalanLabel.Text   = "Awalan: " .. (prefix ~= "" and prefix or "-")
    lastWordLabel.Text = "Kata terakhir: " .. lastWord

    -- Bersihkan daftar lama
    for _, child in ipairs(scrollFrame:GetChildren()) do
        if child:IsA("TextLabel") then
            child:Destroy()
        end
    end

    -- Isi daftar kata baru
    local words = getWordsByPrefix(prefix)
    for i, word in ipairs(words) do
        local item = Instance.new("TextLabel")
        item.Name                = "Word_" .. i
        item.Size                = UDim2.new(1, 0, 0, 24)
        item.BackgroundTransparency = 1
        item.Text                = word
        item.Font                = Enum.Font.Gotham
        item.TextSize            = 13
        item.TextColor3          = Color3.fromRGB(210, 215, 240)
        item.TextXAlignment      = Enum.TextXAlignment.Left
        item.LayoutOrder         = i
        item.Parent              = scrollFrame
    end

    -- Tampilkan pesan kosong jika tidak ada kata
    if #words == 0 then
        local emptyLabel = Instance.new("TextLabel")
        emptyLabel.Name                = "EmptyLabel"
        emptyLabel.Size                = UDim2.new(1, 0, 0, 24)
        emptyLabel.BackgroundTransparency = 1
        emptyLabel.Text                = "(tidak ada kata)"
        emptyLabel.Font                = Enum.Font.Gotham
        emptyLabel.TextSize            = 12
        emptyLabel.TextColor3          = Color3.fromRGB(100, 105, 130)
        emptyLabel.TextXAlignment      = Enum.TextXAlignment.Left
        emptyLabel.Parent              = scrollFrame
    end
end

